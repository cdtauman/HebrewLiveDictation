<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VoiceType.Shell.Controls.StatusChip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Border x:Name="Root" CornerRadius="{StaticResource ChipCornerRadius}"
            Padding="14,7,14,7" Background="{ThemeResource SurfaceSubtleBrush}"
            BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1">
        <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
            <Ellipse x:Name="Dot" Width="9" Height="9" Fill="{ThemeResource TextTertiaryBrush}" />
            <TextBlock x:Name="LabelText" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextSecondaryBrush}" />
        </StackPanel>
    </Border>
</UserControl>
