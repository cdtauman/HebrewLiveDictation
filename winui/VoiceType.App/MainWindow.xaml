<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VoiceType.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" FlowDirection="RightToLeft" Padding="28" RowSpacing="14"
          RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="VoiceType — מעטפת WinUI (Phase 1)"
                   FontSize="26" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="1" x:Name="BridgeStatus" Text="גשר: מתחבר…"
                   FontSize="14" Opacity="0.75"/>
        <TextBlock Grid.Row="2" x:Name="EngineState" Text="מצב מנוע: —"
                   FontSize="14" Opacity="0.75"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10" Margin="0,6,0,0">
            <Button x:Name="StartButton" Content="התחל הכתבה" Click="OnStartClick"/>
            <Button x:Name="StopButton" Content="עצור" Click="OnStopClick"/>
            <Button x:Name="HideButton" Content="הסתר למגש" Click="OnHideClick"/>
            <Button x:Name="ExitButton" Content="יציאה" Click="OnExitClick"/>
        </StackPanel>

        <ScrollViewer Grid.Row="4" Margin="0,8,0,0">
            <TextBlock x:Name="EventLog" FontFamily="Consolas" FontSize="12"
                       TextWrapping="Wrap" Opacity="0.85" FlowDirection="LeftToRight"/>
        </ScrollViewer>

        <TextBlock Grid.Row="5" x:Name="HintText" FontSize="12" Opacity="0.6"
                   Text="סגירת החלון מסתירה אותו למגש המערכת. ההכתבה והקיצורים ממשיכים לפעול ברקע."/>
    </Grid>
</Window>
