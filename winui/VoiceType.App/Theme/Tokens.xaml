<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =====================================================================
         VoiceType design tokens. Calm, premium, RTL-first.
         One serious accent (indigo), neutral surfaces, semantic status colors
         reserved strictly for state. Overrides WinUI's accent fill brushes so
         buttons / selection use our calm accent instead of the loud default.
         ===================================================================== -->
    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Light">
            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1B1E" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5C5F66" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="#8A8D94" />
            <!-- Surfaces -->
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="CardBorderBrush" Color="#ECEDF1" />
            <SolidColorBrush x:Key="SurfaceSubtleBrush" Color="#F5F6F8" />
            <SolidColorBrush x:Key="DividerBrush" Color="#ECEDF1" />
            <!-- Accent (decorative use) -->
            <SolidColorBrush x:Key="AppAccentBrush" Color="#4C5BD4" />
            <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#ECEEFB" />
            <!-- Status (semantic) -->
            <SolidColorBrush x:Key="StatusReadyBrush" Color="#2F9E44" />
            <SolidColorBrush x:Key="StatusAttentionBrush" Color="#E8920C" />
            <SolidColorBrush x:Key="StatusErrorBrush" Color="#E03131" />
            <SolidColorBrush x:Key="StatusReadySoftBrush" Color="#E7F5EA" />
            <SolidColorBrush x:Key="StatusAttentionSoftBrush" Color="#FBF1E0" />
            <SolidColorBrush x:Key="StatusErrorSoftBrush" Color="#FBEAEA" />
            <!-- Retint WinUI accent so AccentButton / selection use our indigo -->
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#4C5BD4" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#5A69DA" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#6E7CE2" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F5F7" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AAAEB7" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="#7B7F88" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1C1E24" />
            <SolidColorBrush x:Key="CardBorderBrush" Color="#2C2F37" />
            <SolidColorBrush x:Key="SurfaceSubtleBrush" Color="#16181D" />
            <SolidColorBrush x:Key="DividerBrush" Color="#2C2F37" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="#8C9CFF" />
            <SolidColorBrush x:Key="AppAccentSoftBrush" Color="#23273A" />
            <SolidColorBrush x:Key="StatusReadyBrush" Color="#51CF66" />
            <SolidColorBrush x:Key="StatusAttentionBrush" Color="#FFB84D" />
            <SolidColorBrush x:Key="StatusErrorBrush" Color="#FF6B6B" />
            <SolidColorBrush x:Key="StatusReadySoftBrush" Color="#1B2A1F" />
            <SolidColorBrush x:Key="StatusAttentionSoftBrush" Color="#2B2417" />
            <SolidColorBrush x:Key="StatusErrorSoftBrush" Color="#2C1C1C" />
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#7C8BF0" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#6E7CE2" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#5A69DA" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- Spacing scale (4-based rhythm) -->
    <x:Double x:Key="SpaceXs">4</x:Double>
    <x:Double x:Key="SpaceSm">8</x:Double>
    <x:Double x:Key="SpaceMd">16</x:Double>
    <x:Double x:Key="SpaceLg">24</x:Double>
    <x:Double x:Key="SpaceXl">32</x:Double>
    <x:Double x:Key="SpaceXxl">48</x:Double>

    <!-- Layout primitives -->
    <Thickness x:Key="PagePadding">40,32,40,40</Thickness>
    <Thickness x:Key="CardPadding">24</Thickness>
    <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="ChipCornerRadius">999</CornerRadius>
    <x:Double x:Key="ContentMaxWidth">1000</x:Double>

</ResourceDictionary>
