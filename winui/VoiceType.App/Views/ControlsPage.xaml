<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VoiceType.Shell.Views.ControlsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="{StaticResource SpaceLg}"
                    MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Center">
            <StackPanel Spacing="4">
                <TextBlock Text="שליטה" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="איך מפעילים ורואים את ההכתבה."
                           Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>

            <!-- Trigger -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="מקש קיצור" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock x:Name="HotkeyHint" Text="לחיצה מפעילה ועוצרת את ההכתבה בכל מקום."
                                       Style="{StaticResource CaptionMutedStyle}" />
                        </StackPanel>
                        <ComboBox x:Name="HotkeyCombo" Grid.Column="1" MinWidth="200" VerticalAlignment="Center"
                                  SelectionChanged="OnHotkeyChanged" />
                    </Grid>
                    <TextBlock x:Name="HotkeyConflict" TextWrapping="Wrap" Visibility="Collapsed"
                               Foreground="#B45309"
                               Text="מקש זה עלול להתנגש עם Windows Copilot. אם ההכתבה לא נפתחת, בחרו מקש אחר (למשל F8)." />
                    <StackPanel Spacing="8">
                        <TextBlock Text="אופן ההפעלה" Style="{StaticResource SectionHeaderStyle}" />
                        <RadioButton x:Name="ModeToggle" GroupName="trigmode" Tag="toggle" Checked="OnModeChoice"
                                     Content="החלפה — לחיצה מתחילה, לחיצה נוספת עוצרת" />
                        <RadioButton x:Name="ModePtt" GroupName="trigmode" Tag="push_to_talk" Checked="OnModeChoice"
                                     Content="לחיצה ממושכת — מקליט כל עוד המקש לחוץ" />
                    </StackPanel>
                    <TextBlock Text="מקש הקיצור חל מיד. אופן ההפעלה ייכנס לתוקף בהפעלה הבאה."
                               Style="{StaticResource CaptionMutedStyle}" />
                </StackPanel>
            </Border>

            <!-- Microphone -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="מיקרופון" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock Text="ההתקן שממנו מקליטים. השינוי חל בהכתבה הבאה."
                                   Style="{StaticResource CaptionMutedStyle}" />
                    </StackPanel>
                    <ComboBox x:Name="MicCombo" Grid.Column="1" MinWidth="240" VerticalAlignment="Center"
                              SelectionChanged="OnMicChanged" />
                </Grid>
            </Border>

            <!-- Audio / VAD advanced controls -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="2">
                        <TextBlock Text="הקלטה ו־VAD" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock Text="הגדרות מתקדמות למיקרופון, חיתוך שקט וזיהוי דיבור."
                                   Style="{StaticResource CaptionMutedStyle}" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="אורך מסגרת" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="קצב הדגימה נשאר 16 kHz; כאן בוחרים את גודל מקטע ההקלטה."
                                       Style="{StaticResource CaptionMutedStyle}" />
                        </StackPanel>
                        <ComboBox x:Name="FrameCombo" Grid.Column="1" MinWidth="180" VerticalAlignment="Center"
                                  SelectionChanged="OnFrameChanged" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="אירועי דיבור בענן" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="Google מקבל סימון התחלה/סיום דיבור כשהמנוע תומך בכך."
                                       Style="{StaticResource CaptionMutedStyle}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="EndpointToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Toggled="OnEndpointingToggled" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="עצירה אוטומטית בשקט" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="כבוי כברירת מחדל; עצירה ידנית נשארת ההתנהגות הבטוחה."
                                       Style="{StaticResource CaptionMutedStyle}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="AutoStopToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Toggled="OnAutoStopToggled" />
                    </Grid>

                    <Grid ColumnDefinitions="*,150" RowDefinitions="Auto,Auto" RowSpacing="10">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="זמן המתנה להתחלת דיבור (שניות)"
                                   VerticalAlignment="Center" />
                        <NumberBox x:Name="SpeechStartTimeoutBox" Grid.Row="0" Grid.Column="1"
                                   Minimum="0.5" Maximum="60" SmallChange="0.5" LargeChange="2"
                                   SpinButtonPlacementMode="Compact" Tag="speech.speech_start_timeout_seconds"
                                   ValueChanged="OnAudioDoubleChanged" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="זמן שקט לסיום דיבור (שניות)"
                                   VerticalAlignment="Center" />
                        <NumberBox x:Name="SpeechEndTimeoutBox" Grid.Row="1" Grid.Column="1"
                                   Minimum="0.5" Maximum="60" SmallChange="0.5" LargeChange="2"
                                   SpinButtonPlacementMode="Compact" Tag="speech.speech_end_timeout_seconds"
                                   ValueChanged="OnAudioDoubleChanged" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="סינון שקט מקומי" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="משחרר למנוע רק מקטעים שנראים כמו דיבור, עם קדם־דיבור קצר."
                                       Style="{StaticResource CaptionMutedStyle}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="VadToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Toggled="OnVadToggled" />
                    </Grid>

                    <Grid ColumnDefinitions="*,220,52" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="סף דיבור" VerticalAlignment="Center" />
                        <Slider x:Name="VadThresholdSlider" Grid.Column="1" Minimum="0.1" Maximum="0.9"
                                StepFrequency="0.05" ValueChanged="OnVadThresholdChanged" />
                        <TextBlock x:Name="VadThresholdValue" Grid.Column="2" TextAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,150" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="קדם־דיבור לשמירה (ms)"
                                   VerticalAlignment="Center" />
                        <NumberBox x:Name="VadPaddingBox" Grid.Row="0" Grid.Column="1"
                                   Minimum="0" Maximum="2000" SmallChange="20" LargeChange="100"
                                   SpinButtonPlacementMode="Compact" Tag="speech.vad_padding_ms"
                                   ValueChanged="OnAudioIntChanged" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="שקט לסגירת VAD (ms)"
                                   VerticalAlignment="Center" />
                        <NumberBox x:Name="VadMinSilenceBox" Grid.Row="1" Grid.Column="1"
                                   Minimum="100" Maximum="5000" SmallChange="50" LargeChange="250"
                                   SpinButtonPlacementMode="Compact" Tag="speech.vad_min_silence_ms"
                                   ValueChanged="OnAudioIntChanged" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="פער שקט ל־Whisper/Groq (ms)"
                                   VerticalAlignment="Center" />
                        <NumberBox x:Name="SegmentSilenceBox" Grid.Row="2" Grid.Column="1"
                                   Minimum="200" Maximum="5000" SmallChange="50" LargeChange="250"
                                   SpinButtonPlacementMode="Compact" Tag="providers.whisper.segment_silence_ms"
                                   ValueChanged="OnAudioIntChanged" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- On-screen surfaces (live) -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="חיוויים על המסך" Style="{StaticResource SectionHeaderStyle}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="חיווי קולי" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="פס קטן בתחתית המסך שמראה שמקשיבים ומה נכתב."
                                       Style="{StaticResource CaptionMutedStyle}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="HudToggle" Grid.Column="1" VerticalAlignment="Center" Toggled="OnHudToggled" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="שלט צף" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="כפתורי התחלה ועצירה צפים שאפשר לגרור לכל מקום."
                                       Style="{StaticResource CaptionMutedStyle}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="RemoteToggle" Grid.Column="1" VerticalAlignment="Center" Toggled="OnRemoteToggled" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Sound — deferred: the WinUI engine path does not play start/stop sounds yet -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="צלילי התחלה ועצירה" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock Text="צליל קצר כשמתחילים וכשעוצרים — יתווסף בקרוב."
                                   Style="{StaticResource CaptionMutedStyle}" />
                    </StackPanel>
                    <ToggleSwitch x:Name="SoundToggle" Grid.Column="1" VerticalAlignment="Center" IsEnabled="False" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
