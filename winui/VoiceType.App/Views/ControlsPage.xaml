<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VoiceType.Shell.Views.ControlsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="{StaticResource SpaceLg}"
                    MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Center">
            <StackPanel Spacing="4">
                <TextBlock Text="שליטה" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="איך מפעילים ורואים את ההכתבה: קיצור מקשים, מיקרופון, חיווי וסרגל."
                           Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="הפעלה ותצוגה" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="כאן תגדירו את קיצור המקשים והלחיצה-לדיבור, את המיקרופון, ואת החיווי הקולי והשלט הצף."
                               Style="{StaticResource BodyMutedStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
