<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VoiceType.Shell.Views.DictationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="{StaticResource SpaceLg}"
                    MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Center">
            <StackPanel Spacing="4">
                <TextBlock Text="הכתבה" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="איך הדיבור שלכם הופך לטקסט: שפה, פקודות קוליות ומילים אישיות."
                           Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="שפה ופקודות" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="כאן תבחרו את שפת ההכתבה, את חבילת הפקודות הקוליות ותוסיפו מילים אישיות לשיפור הזיהוי."
                               Style="{StaticResource BodyMutedStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
