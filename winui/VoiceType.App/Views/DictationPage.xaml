<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VoiceType.Shell.Views.DictationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceType.Shell.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="{StaticResource SpaceLg}"
                    MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Center">
            <StackPanel Spacing="4">
                <TextBlock Text="הכתבה" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="איך הדיבור שלכם הופך לטקסט." Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>

            <!-- Language -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="שפת ההכתבה" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock x:Name="PackLabel" Text="פקודות קוליות: עברית"
                                   Style="{StaticResource CaptionMutedStyle}" />
                    </StackPanel>
                    <!-- Items populated from DictationPage.Languages (one testable source of truth).
                         Google documents iw-IL for Hebrew. he-IL is diagnostic only; Offline maps
                         both to 'he', but Google must be proven by a real transcription probe. -->
                    <ComboBox x:Name="LanguageCombo" Grid.Column="1" MinWidth="200" VerticalAlignment="Center"
                              SelectionChanged="OnLanguageChanged" />
                </Grid>
            </Border>

            <!-- Punctuation -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="פיסוק" Style="{StaticResource SectionHeaderStyle}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="פיסוק אוטומטי" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="המנוע מוסיף נקודות ופסיקים בעצמו."
                                       Style="{StaticResource CaptionMutedStyle}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="AutoPunctToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Toggled="OnAutoPunctToggled" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="פיסוק בדיבור" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="אמרו &quot;נקודה&quot; או &quot;פסיק&quot; והם ייכתבו כסימן."
                                       Style="{StaticResource CaptionMutedStyle}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="SpokenPunctToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Toggled="OnSpokenPunctToggled" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Command pack and phrase adaptation -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Custom words and commands" Style="{StaticResource SectionHeaderStyle}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Command pack" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="Choose which spoken punctuation and editing commands are recognized."
                                       Style="{StaticResource CaptionMutedStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ComboBox x:Name="CommandPackCombo" Grid.Column="1" MinWidth="200"
                                  VerticalAlignment="Center" SelectionChanged="OnCommandPackChanged" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Spoken emoji" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="Allows supported cloud models to turn spoken emoji names into emoji."
                                       Style="{StaticResource CaptionMutedStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="SpokenEmojiToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Toggled="OnSpokenEmojiToggled" />
                    </Grid>

                    <Grid ColumnDefinitions="*,220,52" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="Google phrase boost" VerticalAlignment="Center" />
                        <Slider x:Name="PhraseBoostSlider" Grid.Column="1" Minimum="0" Maximum="20"
                                StepFrequency="1" ValueChanged="OnPhraseBoostChanged" />
                        <TextBlock x:Name="PhraseBoostValue" Grid.Column="2" TextAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Custom phrases" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock Text="One word or phrase per line. Google uses these as speech adaptation hints."
                                   Style="{StaticResource CaptionMutedStyle}" TextWrapping="Wrap" />
                        <TextBox x:Name="CustomPhrasesBox" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="96" PlaceholderText="one term per line"
                                 LostFocus="OnCustomPhrasesLostFocus" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Command reference (live from the active pack) -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                        <TextBlock Text="פקודות קוליות" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock Text="אמרו את הביטוי בזמן ההכתבה והוא יבוצע."
                                   Style="{StaticResource CaptionMutedStyle}" />
                    </StackPanel>

                    <TextBlock Text="סימני פיסוק" Style="{StaticResource SectionHeaderStyle}" />
                    <ItemsControl x:Name="PunctuationList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:CommandRow">
                                <Grid ColumnDefinitions="*,Auto" Padding="0,5,0,5">
                                    <TextBlock Grid.Column="0" Text="{x:Bind Say}"
                                               Foreground="{ThemeResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Effect}"
                                               Style="{StaticResource CaptionMutedStyle}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="פעולות" Style="{StaticResource SectionHeaderStyle}" />
                    <ItemsControl x:Name="ActionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:CommandRow">
                                <Grid ColumnDefinitions="*,Auto" Padding="0,5,0,5">
                                    <TextBlock Grid.Column="0" Text="{x:Bind Say}"
                                               Foreground="{ThemeResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Effect}"
                                               Style="{StaticResource CaptionMutedStyle}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
