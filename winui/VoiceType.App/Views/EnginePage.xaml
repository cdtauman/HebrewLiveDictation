<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VoiceType.Shell.Views.EnginePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="{StaticResource SpaceLg}"
                    MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Center">
            <StackPanel Spacing="4">
                <TextBlock Text="מנוע" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="איכות הזיהוי והחיבור. בוחרים פעם אחת — ושוכחים מזה."
                           Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="בחירת מנוע" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="מומלץ · לא־מקוון · בחירה ידנית — בשפה פשוטה, בלי לחשוף את פרטי המנוע."
                               Style="{StaticResource BodyMutedStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
