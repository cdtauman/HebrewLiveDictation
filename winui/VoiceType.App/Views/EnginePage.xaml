<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VoiceType.Shell.Views.EnginePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="{StaticResource SpaceLg}"
                    MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Center">

            <StackPanel Spacing="4">
                <TextBlock Text="מנוע" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="איכות הזיהוי, חיבורי ענן, והאמת המדויקת של מה שירוץ."
                           Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>

            <!-- Engine choice (plain language; no engine internals on the surface) -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="בחירת מנוע" Style="{StaticResource SectionHeaderStyle}" />
                    <StackPanel Spacing="10">
                        <RadioButton x:Name="OptOffline" GroupName="engine" Tag="offline" Checked="OnEngineChoice">
                            <StackPanel Spacing="2" Margin="6,0,0,0">
                                <TextBlock Text="מומלץ בבטא · לא־מקוון · Whisper" Style="{StaticResource SectionHeaderStyle}" />
                                <TextBlock Text="פרטי לחלוטין ועובד ללא הגדרה. לאחר התקנת המודל הלא־מקוון מטה — עובד בלי חיבור לאינטרנט."
                                           Style="{StaticResource CaptionMutedStyle}" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="OptRecommended" GroupName="engine" Tag="recommended" Checked="OnEngineChoice">
                            <StackPanel Spacing="2" Margin="6,0,0,0">
                                <TextBlock Text="Google (ענן)" Style="{StaticResource SectionHeaderStyle}" />
                                <TextBlock Text="ענן דורש הוכחה לפי השילוב המדויק: מודל, אזור, שפה ו־Recognizer. בדיקת חיבור אינה הוכחת הכתבה; Latest Long הוא הנתיב שנבדק ל‑R3 כשמוגדר בדיוק."
                                           TextWrapping="Wrap" Style="{StaticResource CaptionMutedStyle}" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="OptChoose" GroupName="engine" Tag="choose" Checked="OnEngineChoice">
                            <StackPanel Spacing="2" Margin="6,0,0,0">
                                <TextBlock Text="ספק ענן אחר" Style="{StaticResource SectionHeaderStyle}" />
                                <TextBlock Text="Deepgram זמין לבדיקה עם מפתח API מאובטח. Groq יושלם בשלב הבא."
                                           Style="{StaticResource CaptionMutedStyle}" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                    <TextBlock x:Name="CurrentLabel" Style="{StaticResource CaptionMutedStyle}" />
                    <TextBlock x:Name="ProviderStatusText" Style="{StaticResource CaptionMutedStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="שפות: לא־מקוון (Whisper) תומך בשפות רבות. ב‑Google יש להוכיח את קוד השפה מול המודל והאזור. בוחרים שפה בחדר 'הכתבה'."
                               Style="{StaticResource CaptionMutedStyle}" TextWrapping="Wrap" />
                    <TextBlock Text="השינוי ייכנס לתוקף בהכתבה הבאה." Style="{StaticResource CaptionMutedStyle}" />
                </StackPanel>
            </Border>

            <!-- Google Cloud setup (PC1) — shown only when Google is the selected engine -->
            <Border x:Name="GoogleCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                <StackPanel Spacing="12">
                    <TextBlock Text="הגדרת Google Cloud" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock x:Name="GoogleStatusText" Style="{StaticResource CaptionMutedStyle}"
                               TextWrapping="Wrap" Text="בודק מצב…" />
                    <!-- Active runtime config (R3 item 5): exactly what will run — no log-reading needed. -->
                    <TextBlock x:Name="GoogleActiveText" Style="{StaticResource CaptionMutedStyle}"
                               TextWrapping="Wrap" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="Project ID" Style="{StaticResource CaptionMutedStyle}" />
                        <TextBox x:Name="ProjectIdBox" LostFocus="OnProjectIdChanged" PlaceholderText="my-gcp-project" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="אזור (Region)" Style="{StaticResource CaptionMutedStyle}" />
                            <ComboBox x:Name="LocationCombo" HorizontalAlignment="Stretch" SelectionChanged="OnLocationChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="מודל" Style="{StaticResource CaptionMutedStyle}" />
                            <ComboBox x:Name="GoogleModelCombo" HorizontalAlignment="Stretch" SelectionChanged="OnGoogleModelChanged" />
                        </StackPanel>
                    </Grid>
                    <!-- Honest per-model guidance: live words vs final-only, short vs long (R3 item 2). -->
                    <TextBlock x:Name="GoogleModelMetaText" Style="{StaticResource CaptionMutedStyle}" TextWrapping="Wrap" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="מזהה Recognizer (ברירת מחדל: _)" Style="{StaticResource CaptionMutedStyle}" />
                        <TextBox x:Name="RecognizerBox" LostFocus="OnRecognizerChanged" PlaceholderText="_" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="אופן ההזדהות" Style="{StaticResource CaptionMutedStyle}" />
                        <ComboBox x:Name="CredModeCombo" HorizontalAlignment="Stretch" SelectionChanged="OnCredModeChanged">
                            <ComboBoxItem Tag="service_account_json" Content="קובץ Service Account (JSON)" />
                            <ComboBoxItem Tag="adc" Content="Application Default Credentials (gcloud)" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="CredPathRow" Spacing="4">
                        <TextBlock Text="קובץ ההרשאות (JSON)" Style="{StaticResource CaptionMutedStyle}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox x:Name="CredPathBox" Grid.Column="0" IsReadOnly="True" PlaceholderText="לא נבחר קובץ" />
                            <Button x:Name="BrowseCredBtn" Grid.Column="1" Content="עיון…" Click="OnBrowseCredentials" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Button x:Name="TestConnBtn" Content="בדיקת חיבור" Click="OnTestConnection" />
                        <ProgressRing x:Name="TestRing" IsActive="False" Visibility="Collapsed" Width="20" Height="20" />
                    </StackPanel>
                    <TextBlock x:Name="TestStatusText" Style="{StaticResource CaptionMutedStyle}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Provider picker — only when 'choose' is selected -->
            <Border x:Name="ChooseCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="ספק זיהוי" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="Deepgram supports live streaming. Groq uses final-only Whisper transcription. Both store API keys in Windows Credential Manager and require Test connection before use."
                               Style="{StaticResource CaptionMutedStyle}" TextWrapping="Wrap" />
                    <ComboBox x:Name="ProviderCombo" MinWidth="240" SelectionChanged="OnProviderChanged">
                        <ComboBoxItem Tag="deepgram" Content="Deepgram" />
                        <ComboBoxItem Tag="groq" Content="Groq" />
                    </ComboBox>
                    <StackPanel x:Name="DeepgramModelRow" Spacing="4">
                        <TextBlock Text="Deepgram model" Style="{StaticResource CaptionMutedStyle}" />
                        <ComboBox x:Name="DeepgramModelCombo" HorizontalAlignment="Stretch"
                                  SelectionChanged="OnDeepgramModelChanged" />
                    </StackPanel>
                    <StackPanel x:Name="GroqModelRow" Spacing="4" Visibility="Collapsed">
                        <TextBlock Text="Groq model" Style="{StaticResource CaptionMutedStyle}" />
                        <ComboBox x:Name="GroqModelCombo" HorizontalAlignment="Stretch"
                                  SelectionChanged="OnGroqModelChanged" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="API key" Style="{StaticResource CaptionMutedStyle}" />
                        <PasswordBox x:Name="ProviderKeyBox" PlaceholderText="Paste API key to save in OS keyring" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="SaveProviderKeyBtn" Content="שמור מפתח" Click="OnSaveProviderKey" />
                        <Button x:Name="ClearProviderKeyBtn" Content="נקה מפתח" Click="OnClearProviderKey" />
                        <Button x:Name="TestProviderBtn" Content="בדיקת Deepgram" Click="OnTestProviderConnection" />
                        <ProgressRing x:Name="ProviderTestRing" IsActive="False" Visibility="Collapsed" Width="20" Height="20" />
                    </StackPanel>
                    <TextBlock x:Name="ProviderKeyStatusText" Style="{StaticResource CaptionMutedStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="ProviderTestStatusText" Style="{StaticResource CaptionMutedStyle}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Offline backup — plain-language wrapper over stt.mode=auto_fallback -->
            <Border x:Name="BackupCard" Style="{StaticResource CardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="גיבוי לא־מקוון אם הענן נופל" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock Text="אם החיבור לענן נכשל, נמשיך אוטומטית עם המנוע המקומי."
                                   Style="{StaticResource CaptionMutedStyle}" />
                    </StackPanel>
                    <ToggleSwitch x:Name="BackupToggle" Grid.Column="1" VerticalAlignment="Center"
                                  Toggled="OnBackupToggled" />
                </Grid>
            </Border>

            <!-- Offline model management. Offline dictation needs a local model; we report its
                 real on-disk status and let the user download or remove it. Never claims ready
                 unless the model is actually, completely present. -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="מודל לא־מקוון" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="בחרו מודל. מודל גדול יותר = איכות טובה יותר, אך איטי יותר ודורש יותר זיכרון."
                               Style="{StaticResource CaptionMutedStyle}" TextWrapping="Wrap" />
                    <ComboBox x:Name="ModelCombo" MinWidth="300" HorizontalAlignment="Stretch"
                              SelectionChanged="OnModelSelected" />
                    <TextBlock x:Name="ModelMetaText" Style="{StaticResource CaptionMutedStyle}" TextWrapping="Wrap" />
                    <TextBlock x:Name="ModelStatusText" Style="{StaticResource CaptionMutedStyle}"
                               TextWrapping="Wrap" Text="בודק מצב מודל…" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Button x:Name="ModelDownloadBtn" Content="הורד מודל" Click="OnDownloadModel" />
                        <Button x:Name="ModelDeleteBtn" Content="מחק מודל" Click="OnDeleteModel"
                                Visibility="Collapsed" />
                        <ProgressRing x:Name="ModelRing" IsActive="False" Visibility="Collapsed"
                                      Width="20" Height="20" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
