<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VoiceType.Shell.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceType.Shell.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="{StaticResource SpaceLg}"
                    MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Center">

            <TextBlock Text="ברוכים הבאים" Style="{StaticResource PageTitleStyle}" />

            <!-- Ready hero -->
            <Border Style="{StaticResource CardStyle}" Padding="32">
                <StackPanel Spacing="18">
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <Ellipse Width="16" Height="16" Fill="{ThemeResource StatusReadyBrush}" />
                        <TextBlock x:Name="StatusText" Text="מוכן" Style="{StaticResource DisplayTextStyle}" />
                    </StackPanel>
                    <TextBlock Text="לחצו F8 בכל מקום כדי להכתיב — הטקסט ייכתב היכן שאתם עובדים."
                               Style="{StaticResource PageSubtitleStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="התחל הכתבה" Style="{StaticResource AccentButtonStyle}" Click="OnStart" />
                        <Button Content="עצור" Click="OnStop" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Health strip -->
            <StackPanel Spacing="10">
                <TextBlock Text="מצב המערכת" Style="{StaticResource SectionHeaderStyle}" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <controls:StatusChip Text="מנוע · Google Chirp 3" State="ready" />
                    <controls:StatusChip Text="מיקרופון" State="ready" />
                    <controls:StatusChip Text="גיבוי לא־מקוון" State="neutral" />
                </StackPanel>
            </StackPanel>

            <!-- Recent activity -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="פעילות אחרונה" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="התמלולים האחרונים שלכם יופיעו כאן." Style="{StaticResource BodyMutedStyle}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
