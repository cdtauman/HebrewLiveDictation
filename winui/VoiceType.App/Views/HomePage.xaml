<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VoiceType.Shell.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoiceType.Shell.Controls"
    xmlns:local="using:VoiceType.Shell.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="{StaticResource SpaceLg}"
                    MaxWidth="{StaticResource ContentMaxWidth}" HorizontalAlignment="Center">

            <TextBlock Text="ברוכים הבאים" Style="{StaticResource PageTitleStyle}" />

            <!-- Ready hero (live) -->
            <Border Style="{StaticResource CardStyle}" Padding="32">
                <StackPanel Spacing="18">
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="16" Height="16"
                                 Fill="{ThemeResource StatusReadyBrush}" />
                        <TextBlock x:Name="StatusText" Text="מוכן" Style="{StaticResource DisplayTextStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="StatusHint"
                               Text="לחצו F8 בכל מקום כדי להכתיב — הטקסט ייכתב היכן שאתם עובדים."
                               Style="{StaticResource PageSubtitleStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="PrimaryButton" Content="התחל הכתבה"
                                Style="{StaticResource AccentButtonStyle}" Click="OnPrimary" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Health strip (live) -->
            <StackPanel Spacing="10">
                <TextBlock Text="מצב המערכת" Style="{StaticResource SectionHeaderStyle}" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <controls:StatusChip x:Name="EngineChip" Text="מנוע" State="neutral" />
                    <controls:StatusChip x:Name="MicChip" Text="מיקרופון" State="neutral" />
                    <controls:StatusChip x:Name="OfflineChip" Text="גיבוי לא־מקוון" State="neutral" />
                </StackPanel>
            </StackPanel>

            <!-- Recent activity (live) -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="פעילות אחרונה" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock x:Name="RecentEmpty" Text="התמלולים האחרונים שלכם יופיעו כאן."
                               Style="{StaticResource BodyMutedStyle}" />
                    <ListView x:Name="RecentList" SelectionMode="None" IsItemClickEnabled="False"
                              Visibility="Collapsed" Margin="-12,0,-12,0">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:RecentItem">
                                <Grid ColumnDefinitions="*,Auto" Padding="0,8,0,8">
                                    <TextBlock Grid.Column="0" Text="{x:Bind Text}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextPrimaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind When}"
                                               Style="{StaticResource CaptionMutedStyle}"
                                               VerticalAlignment="Center" Margin="12,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
